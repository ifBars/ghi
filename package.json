{
  "name": "ghi-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "bun run --cwd packages/cli test",
    "check": "bun run --cwd packages/shared check && bun run --cwd packages/cli check && bun run --cwd apps/mobile check",
    "build": "bun run --cwd packages/cli build",
    "smoke:node": "bun run --cwd packages/cli smoke:node",
    "dev:cli": "bun run --cwd packages/cli dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "check:mobile": "bun run --cwd apps/mobile check",
    "score:issues": "bun tools/score_issues.ts score tools/issue-corpus/scheduleone-good.jsonl",
    "score:issues:good": "bun tools/score_issues.ts score tools/issue-corpus/scheduleone-good.jsonl tools/issue-corpus/production-good.jsonl --min-score 75 --min-average 80",
    "score:issues:weak": "bun tools/score_issues.ts score tools/issue-corpus/scheduleone-weak.jsonl --max-score 65 --max-average 52",
    "score:issues:rejected": "bun tools/score_issues.ts score tools/issue-corpus/maintainer-rejected.jsonl --max-score 85 --max-average 68",
    "score:issues:audit": "bun tools/score_issues.ts audit tools/issue-corpus/scheduleone-good.jsonl tools/issue-corpus/production-good.jsonl tools/issue-corpus/scheduleone-weak.jsonl tools/issue-corpus/maintainer-rejected.jsonl",
    "score:issues:check": "bun tools/score_issues.ts check tools/issue-corpus/manifest.json",
    "test:score": "bun test tools/score_issues.test.ts"
  }
}
